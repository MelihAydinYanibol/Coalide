# Coalide parental stats server — configuration.
# Copy this file to ".env" (next to server.py) and fill in your values,
# or set these as real environment variables. The ".env" file is gitignored.

# --- Daily report channels ---
# The daily report can go to Telegram, ntfy.sh, or both. Configure either or
# both below; each is independent. Leave bracketed placeholders as-is to keep a
# channel OFF (the server treats any value starting with "[" as "not configured").

# Telegram: create a bot with @BotFather to get the token; get your chat id from
# @userinfobot.
TELEGRAM_BOT_TOKEN=[YOUR_BOT_TOKEN]
TELEGRAM_CHAT_ID=[YOUR_CHAT_ID]

# ntfy.sh: pick any hard-to-guess topic name and subscribe to it in the ntfy app
# or at https://ntfy.sh/<your-topic>. Just setting NTFY_TOPIC is enough.
NTFY_TOPIC=[YOUR_NTFY_TOPIC]
# Self-hosted ntfy server (optional; defaults to https://ntfy.sh).
# NTFY_SERVER=https://ntfy.sh
# Access token for a protected/self-hosted topic (optional).
# NTFY_TOKEN=[YOUR_NTFY_TOKEN]
# Alternatively, give the full topic URL directly (overrides NTFY_SERVER+TOPIC).
# NTFY_URL=https://ntfy.sh/your-topic

# When to send the daily report (24h local time). Default: midnight.
COALIDE_REPORT_TIME=00:00

# Turn the daily report on/off explicitly. If omitted, it is ON automatically
# whenever at least one channel (Telegram or ntfy) is configured.
# COALIDE_REPORT_ENABLED=true

# The dashboard link shown at the end of the report. If omitted, it is built
# from the server host/port. Set this to the address the parent actually uses.
COALIDE_DASHBOARD_URL=http://192.168.1.50:5055/

# --- Server binding (optional; can also be passed as env vars) ---
# COALIDE_STATS_HOST=0.0.0.0
# COALIDE_STATS_PORT=5055
